# ============================================================
# Studio Yoga — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# -- Site --
NEXT_PUBLIC_SITE_URL=http://localhost:3000
STUDIO_NAME="Studio Yoga"

# -- Supabase --
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -- Stripe --
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Carte 10 séances — 120€
STRIPE_PRICE_10_SESSIONS=price_...
# Carte 20 séances — 220€
STRIPE_PRICE_20_SESSIONS=price_...

# -- SMTP (o2switch ou autre hébergeur) --
# cPanel → Comptes de messagerie → Configurer le client
SMTP_HOST=mail.yoga.ayur-jyotish.fr
SMTP_PORT=587
SMTP_USER=noreply@yoga.ayur-jyotish.fr
SMTP_PASSWORD=xxx

# -- Cron job security --
# Générez une chaîne aléatoire longue
CRON_SECRET=your-super-secret-cron-token-here
