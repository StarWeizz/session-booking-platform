# ============================================================
# Studio Yoga — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# -- Site --
NEXT_PUBLIC_SITE_URL=http://localhost:3000
STUDIO_NAME="Studio Yoga"

# -- Supabase --
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -- Stripe --
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Carte 10 séances — 120€
STRIPE_PRICE_10_SESSIONS=price_...
# Carte 20 séances — 220€
STRIPE_PRICE_20_SESSIONS=price_...

# -- Resend --
# resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@votrestudio.fr

# -- Cron job security --
# Générez une chaîne aléatoire longue
CRON_SECRET=your-super-secret-cron-token-here
